# URL ของ Discord Webhook สำหรับแจ้งเตือนลิงก์ที่เข้าใช้งานได้ (จำเป็นต้องใส่เพื่อให้ส่งข้อความแจ้งเตือน)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1509011675678900375/tXUswk0nDcVupjrzyLDcSi0MA8gJgRM7O4QidOM705Udc6Z7QsGIQebK7KgV0PngpOqj

# === ตัวเลือกสำหรับ Cloudflare Tunnel ===

# 1. กรณีต้องการใช้ Quick Tunnel (โดเมนสุ่มฟรี เช่น https://xxx.trycloudflare.com)
# ให้เว้นว่างช่อง TUNNEL_TOKEN และ PUBLIC_URL ไว้

# 2. กรณีต้องการใช้ Named Tunnel (โดเมนคงที่ของตัวเอง เช่น https://afs.yourdomain.com)
# ให้ใส่ Token และ URL ของคุณที่นี่
TUNNEL_TOKEN=
PUBLIC_URL=

# พอร์ตสำหรับบริการเว็บ (ค่าเริ่มต้นของ Dockerfile คือ 10000)
PORT=10000
